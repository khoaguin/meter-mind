# Copy to .env and fill in. `.env` is gitignored; this template is committed.
#   cp .env.example .env

# --- LLM for explain_anomaly (the one model call in the hub) ---
# Any litellm model string. Default is Claude (best for this task); swap freely:
#   anthropic/claude-opus-4-8   openai/gpt-4o   gemini/gemini-1.5-flash
#   ollama/llama3 (local, no key)   huggingface/<repo>
LLM_MODEL=anthropic/claude-opus-4-8

# Provider API key — set the ONE that matches LLM_MODEL (litellm picks it by prefix).
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# HUGGINGFACE_API_KEY=
# Ollama runs locally and needs no key; set this only if it's not on localhost:11434.
# OLLAMA_API_BASE=http://localhost:11434

# --- Hub SQLite DB (one file; teardown = delete it). Read at import in hub.db.session. ---
# HUB_DB_PATH=data/hub.db

# --- MCP server port. Cloud Run injects PORT; local default is 8000. ---
# PORT=8000
