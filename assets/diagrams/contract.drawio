        <mxCell id="lg1t" value="Native jomjol - byte-exact; a real chip emits these too" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;fontColor=#dbe4f0;" vertex="1" parent="leg"><mxGeometry x="52" y="36" width="440" height="20" as="geometry" /></mxCell>
        <mxCell id="lg2" value="" style="rounded=0;html=1;fillColor=#221a33;strokeColor=#a78bfa;fontFamily=Courier New;fontColor=#dbe4f0;" vertex="1" parent="leg"><mxGeometry x="16" y="72" width="26" height="16" as="geometry" /></mxCell>
        <mxCell id="lg2t" value="The /json payload - the single source of truth (all 6)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;fontColor=#dbe4f0;" vertex="1" parent="leg"><mxGeometry x="52" y="70" width="460" height="20" as="geometry" /></mxCell>
        <mxCell id="lg3" value="" style="rounded=0;html=1;fillColor=#0a2b1e;strokeColor=#34d399;fontFamily=Courier New;fontColor=#dbe4f0;" vertex="1" parent="leg"><mxGeometry x="16" y="106" width="26" height="16" as="geometry" /></mxCell>
        <mxCell id="lg3t" value="Additive (ours) - powers billing + the low-confidence loop" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;fontColor=#dbe4f0;" vertex="1" parent="leg"><mxGeometry x="52" y="104" width="460" height="20" as="geometry" /></mxCell>

