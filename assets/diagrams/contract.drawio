        <mxCell id="e_sm" value="MQTT" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;labelBackgroundColor=#0a0f1c;exitX=1;exitY=0.5;entryX=0;entryY=0.3;endArrow=classic;strokeWidth=2;strokeColor=#34d399;fontFamily=Courier New;fontColor=#dbe4f0;" edge="1" parent="1" source="psim" target="main"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_rm" value="MQTT" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;labelBackgroundColor=#0a0f1c;exitX=1;exitY=0.5;entryX=0;entryY=0.7;endArrow=classic;strokeWidth=2;strokeColor=#e8b339;dashed=1;fontFamily=Courier New;fontColor=#dbe4f0;" edge="1" parent="1" source="preal" target="main"><mxGeometry relative="1" as="geometry" /></mxCell>

