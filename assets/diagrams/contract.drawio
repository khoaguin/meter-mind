<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="30.2.6">
  <diagram name="MQTT-Contract-Seam">
    <mxGraphModel background="#0a0f1c" dx="900" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1260" pageHeight="660" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="ttl" value="The contract is the seam - sim and real chip publish byte-identical topics" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=18;fontColor=#e6eefb;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="40" y="14" width="1180" height="28" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="a downstream hub cannot tell which producer sent a reading - that is the whole point" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#9fb0c3;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="40" y="44" width="1180" height="22" as="geometry" />
        </mxCell>

        <!-- Producers -->
        <mxCell id="psim" value="&lt;b&gt;edgesim&lt;/b&gt;&lt;br&gt;virtual fleet [built]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a2b1e;strokeColor=#34d399;fontColor=#dbe4f0;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="preal" value="&lt;b&gt;Real ESP32-CAM&lt;/b&gt;&lt;br&gt;drop-in later" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#33240a;strokeColor=#e8b339;dashed=1;fontColor=#dbe4f0;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- MainTopic node -->
        <mxCell id="main" value="&lt;b&gt;MainTopic&lt;/b&gt;&lt;br&gt;e.g. kiosk1-water" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#221a33;strokeColor=#a78bfa;fontColor=#dbe4f0;fontSize=13;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="330" y="240" width="180" height="90" as="geometry" />
        </mxCell>

        <!-- Flat fields: header + 5 word chips -->
        <mxCell id="fhdr" value="&lt;b&gt;Flat fields - native (5)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0c2530;strokeColor=#2dd4bf;fontColor=#dbe4f0;fontSize=13;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="620" y="86" width="600" height="36" as="geometry" />
        </mxCell>
        <mxCell id="ch1" value="value" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0c2530;strokeColor=#2dd4bf;fontColor=#dbe4f0;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="620" y="130" width="108" height="34" as="geometry" /></mxCell>
        <mxCell id="ch2" value="raw" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0c2530;strokeColor=#2dd4bf;fontColor=#dbe4f0;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="740" y="130" width="108" height="34" as="geometry" /></mxCell>
        <mxCell id="ch3" value="error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0c2530;strokeColor=#2dd4bf;fontColor=#dbe4f0;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="860" y="130" width="108" height="34" as="geometry" /></mxCell>
        <mxCell id="ch4" value="rate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0c2530;strokeColor=#2dd4bf;fontColor=#dbe4f0;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="980" y="130" width="108" height="34" as="geometry" /></mxCell>
        <mxCell id="ch5" value="timestamp" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0c2530;strokeColor=#2dd4bf;fontColor=#dbe4f0;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="1100" y="130" width="120" height="34" as="geometry" /></mxCell>

        <mxCell id="json" value="&lt;b&gt;/json - native (all 6)&lt;/b&gt;&lt;br&gt;the single source of truth : values are strings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#221a33;strokeColor=#a78bfa;fontColor=#dbe4f0;fontSize=13;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="620" y="190" width="600" height="66" as="geometry" />
        </mxCell>

        <mxCell id="add" value="&lt;b&gt;confidence + MeterType&lt;/b&gt;&lt;br&gt;additive (ours) : a real chip omits both" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a2b1e;strokeColor=#34d399;fontColor=#dbe4f0;fontSize=13;fontFamily=Courier New;" vertex="1" parent="1">
