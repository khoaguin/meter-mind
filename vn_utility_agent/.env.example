# Local `adk run` / `adk web` config for the VN utility agent (Vertex AI backend,
# ADC auth — run `gcloud auth application-default login` first). Copy to `.env`
# in this directory; the adk CLI loads it automatically. No secrets here.
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=ai-playground-458112
GOOGLE_CLOUD_LOCATION=global
